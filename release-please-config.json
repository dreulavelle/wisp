{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "json",
          "path": "cmd/silo-plugin-wisp/manifest.json",
          "jsonpath": "$.version"
        }
      ],
      "draft": true
    }
  },
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "perf",
      "section": "Performance"
    },
    {
      "type": "refactor",
      "section": "Refactoring"
    },
    {
      "type": "docs",
      "section": "Documentation",
      "hidden": true
    },
    {
      "type": "chore",
      "section": "Chores",
      "hidden": true
    }
  ]
}
