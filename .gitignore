# ── Secrets: never commit real env or credential files ─────────────────────
.env
.env.*
!.env.example
secrets.*
credentials.*
*.key
*.pem
*.crt
*_rsa
*_ed25519

# ── Build artifacts ────────────────────────────────────────────────────────
/dist/
/wisp
# The compiled plugin binary, wherever `go build` drops it. Anchored so it does
# NOT swallow the cmd/silo-plugin-wisp/ source directory (a bare pattern would
# match the dir too, silently hiding every source and test file under it).
/silo-plugin-wisp
/cmd/silo-plugin-wisp/silo-plugin-wisp
*.exe
*.out
*.test
coverage.*

# ── Test scratch: written by test/e2e/run.sh, never committed ──────────────
repository.e2e.json
test/e2e/library/
test/e2e/stub-bin

# ── Runtime data ───────────────────────────────────────────────────────────
/data/
*.db
*.db-shm
*.db-wal

# ── Editor / OS cruft ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Local Silo API key for scripts/dev-install.sh — never commit
scripts/.silo-key
