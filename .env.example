# Wisp runs as a Silo plugin and is configured in Silo's admin UI, not here.
#
# This file exists only for the end-to-end suite and local development:
#
#   set -a && . ./.env && set +a && go test ./internal/plugin/ -run TestLive -v
#
# Full AIOStreams manifest URL, copied from its configure page.
WISP_AIOSTREAMS_URL=https://aiostreams.example.com/stremio/<uuid>/manifest.json
# Password for that instance, if it has one.
WISP_AIOSTREAMS_PASSWORD=
